{
  "name": "devops-pipeline-app",
  "version": "1.0.0",
  "description": "Sample Express app for a DevOps pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "test:selenium": "node test/selenium.test.js",
    "test:integration": "node test/integration.test.js",
    "test:all": "npm run test && npm run test:integration && npm run test:selenium",
    "test:coverage": "c8 npm test"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "express": "^4.18.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "selenium-webdriver": "^4.20.0",
    "chromedriver": "^124.0.0",
    "c8": "^8.0.1"
  }
}
